/* app.wxss - 全局样式 */

/* === CSS 变量 / 设计令牌 === */
page {
  --color-primary: #D4776B;        /* 暖陶红 - 主色调 */
  --color-primary-light: #F0C8C1;  /* 浅粉 */
  --color-bg: #FFF8F0;             /* 暖白 - 背景 */
  --color-bg-card: #FFFAF5;        /* 卡片背景 */
  --color-text: #4A3728;           /* 深棕 - 正文 */
  --color-text-light: #8B7D6B;     /* 浅棕 - 辅助文字 */
  --color-accent: #C9A96E;         /* 暖金 - 点缀 */
  --color-green: #7BA07B;          /* 墨绿 - 自然元素 */
  --color-border: #E8D5C4;         /* 边框 */

  --font-title: 'Georgia', 'Times New Roman', serif;
  --font-body: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;

  --shadow-card: 0 2rpx 12rpx rgba(74, 55, 40, 0.08);
  --shadow-float: 0 4rpx 20rpx rgba(74, 55, 40, 0.12);
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;

  box-sizing: border-box;
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
  font-size: 28rpx;
  line-height: 1.6;
}

/* === 通用工具类 === */
.page-container {
  min-height: 100vh;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.card {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.text-center { text-align: center; }
.text-muted { color: var(--color-text-light); font-size: 24rpx; }

/* 水彩纸张纹理叠加层 */
.paper-texture {
  position: relative;
}
.paper-texture::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  opacity: 0.03;
  background-image: url('data:image/svg+xml,...'); /* 后续替换为真实纹理 */
}
