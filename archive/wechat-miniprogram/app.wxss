/* app.wxss - 全局样式 — Undertale 像素RPG风格 */

/* === CSS 变量 / 设计令牌 === */
page {
  /* Undertale 灵魂色系 */
  --color-primary: #FF0000;        /* 灵魂红 - 主色调（决心） */
  --color-primary-light: #FF4444;  /* 浅红 */
  --color-bg: #000000;             /* 纯黑 - 背景（战斗/对话框底色） */
  --color-bg-card: #1A1A2E;        /* 深蓝黑 - 卡片背景 */
  --color-text: #FFFFFF;           /* 纯白 - 正文 */
  --color-text-light: #AAAAAA;     /* 灰白 - 辅助文字 */
  --color-accent: #FFD700;         /* 金黄 - 点缀（存档点/SAVE） */
  --color-green: #00E500;          /* 像素绿 - 自然/HP */
  --color-border: #FFFFFF;         /* 白色边框 - 对话框风格 */
  --color-overworld-grass: #2D5A1E;/* 大地图草地绿 */
  --color-overworld-path: #C8A96E; /* 大地图路径土色 */

  /* Undertale 风格字体：像素等宽 */
  --font-pixel: 'Courier New', 'Consolas', 'Monaco', monospace;
  --font-title: 'Courier New', 'Consolas', monospace;
  --font-body: 'Courier New', 'Consolas', 'Microsoft YaHei', monospace;

  /* 像素风无圆角 */
  --shadow-card: 4rpx 4rpx 0rpx #FFFFFF;  /* 白色硬阴影（像素偏移感） */
  --shadow-float: 6rpx 6rpx 0rpx #FF0000;  /* 红色硬阴影 */
  --radius-sm: 0rpx;    /* 无圆角 = 纯像素风 */
  --radius-md: 0rpx;
  --radius-lg: 0rpx;

  box-sizing: border-box;
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
  font-size: 28rpx;
  line-height: 1.6;
  image-rendering: pixelated;      /* 关键！所有图片像素渲染 */
}

/* === 通用工具类 === */
.page-container {
  min-height: 100vh;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.card {
  background: var(--color-bg-card);
  border: 4rpx solid var(--color-border);
  /* 无圆角 + 白色边框 = Undertale 对话框 */
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.text-center { text-align: center; }
.text-muted { color: var(--color-text-light); font-size: 24rpx; }

/* 像素扫描线叠加层（复古CRT感） */
.scanline-overlay {
  position: relative;
}
.scanline-overlay::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  opacity: 0.04;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2rpx,
    rgba(255,255,255,0.03) 2rpx,
    rgba(255,255,255,0.03) 4rpx
  );
}
