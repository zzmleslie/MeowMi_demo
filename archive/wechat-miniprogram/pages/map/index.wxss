/* pages/map/index.wxss */
.map-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #E8F0D8;
}

/* === Canvas 地图 === */
.map-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
}

/* === 摇杆 === */
.joystick-container {
  position: absolute;
  left: 40rpx;
  bottom: 120rpx;
  width: 140rpx;
  height: 140rpx;
  z-index: 10;
}

.joystick-base {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 3rpx solid rgba(180, 150, 130, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.joystick-thumb {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(212, 119, 107, 0.6);
  position: relative;
  left: 0;
  top: 0;
  margin-left: -30rpx;
  margin-top: -30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

/* === 发现提示 === */
.discover-toast {
  position: absolute;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  box-shadow: var(--shadow-float);
  display: flex;
  align-items: center;
  gap: 16rpx;
  opacity: 0;
  transition: opacity 0.3s, transform 0.3s;
  transform: translateX(-50%) translateY(-10rpx);
  pointer-events: none;
  z-index: 20;
}

.discover-toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
  pointer-events: auto;
  animation: toastPulse 2s ease-in-out infinite;
}

@keyframes toastPulse {
  0%, 100% { box-shadow: 0 4rpx 20rpx rgba(212, 119, 107, 0.3); }
  50% { box-shadow: 0 4rpx 30rpx rgba(212, 119, 107, 0.6); }
}

.toast-icon { font-size: 48rpx; }

.toast-text { display: flex; flex-direction: column; }

.toast-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.toast-hint {
  font-size: 22rpx;
  color: var(--color-primary);
}

/* === 发现计数徽章 === */
.discovery-badge {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
  z-index: 10;
}

/* === 猫咪弹窗 === */
.cat-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  display: flex;
  align-items: flex-end;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
}

.cat-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
}

.modal-content {
  position: relative;
  background: var(--color-bg);
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  max-height: 70vh;
  overflow-y: auto;
  width: 100%;
  box-sizing: border-box;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 猫咪头像区 */
.cat-avatar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.cat-photo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-border);
}

.cat-name-tag { display: flex; flex-direction: column; }

.cat-name {
  font-family: var(--font-title);
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text);
}

.cat-nickname {
  font-size: 26rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
}

/* 信息网格 */
.cat-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.info-item {
  background: var(--color-bg-card);
  border-radius: var(--radius-sm);
  padding: 16rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--color-text-light);
  display: block;
}

.info-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.info-value.done { color: var(--color-green); }
.info-value.pending { color: #E8A87C; }

/* 描述 */
.cat-desc, .cat-location, .cat-family {
  margin-bottom: 20rpx;
}

.desc-label, .loc-label, .family-label {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: block;
  margin-bottom: 6rpx;
}

.desc-text, .loc-text {
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
}

.family-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.family-item { font-size: 24rpx; color: var(--color-text); }
.family-name { color: var(--color-primary); }

/* 按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.primary {
  background: var(--color-primary);
  color: #FFF;
  border: none;
}

.action-btn:not(.primary) {
  background: var(--color-bg-card);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
}

/* === 小地图 === */
.minimap {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  z-index: 10;
}

.minimap-canvas {
  width: 100%;
  height: 100%;
}
