/* pages/index/index.wxss */
.home-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F0 0%, #FDF1E6 40%, #FBEBD9 100%);
}

/* === Hero 区域 === */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-emoji {
  font-size: 120rpx;
  line-height: 1;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.main-title {
  font-family: var(--font-title);
  font-size: 56rpx;
  font-weight: bold;
  color: var(--color-text);
  letter-spacing: 8rpx;
  margin-top: 20rpx;
}

.sub-title {
  font-size: 22rpx;
  color: var(--color-text-light);
  letter-spacing: 4rpx;
  margin-top: 8rpx;
}

.motto {
  margin-top: 30rpx;
  text-align: center;
}

.motto-text {
  font-size: 26rpx;
  color: var(--color-primary);
  font-style: italic;
}

.motto-location {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 6rpx;
}

/* === 功能卡片 === */
.feature-cards {
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.feature-card {
  display: flex;
  align-items: center;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  transition: transform 0.2s;
}

.feature-card:active {
  transform: scale(0.97);
}

.card-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
}

.card-arrow {
  font-size: 32rpx;
  color: var(--color-text-light);
  flex-shrink: 0;
}

.card-tag {
  font-size: 20rpx;
  color: var(--color-text-light);
  background: #F0EDE8;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.disabled-card {
  opacity: 0.5;
}

/* === 统计区 === */
.stats-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
  padding: 30rpx 40rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-lg);
  margin-bottom: 50rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
}

.stat-number {
  font-family: var(--font-title);
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: var(--color-border);
}

/* === 底部 === */
.footer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.footer-version {
  font-size: 20rpx;
  color: #CCC;
  margin-top: 6rpx;
}
