<!-- pages/index/index.wxml - 首页 -->
<view class="page-container home-page">
  
  <!-- Logo & 标题区 -->
  <view class="hero-section">
    <view class="logo-area">
      <text class="logo-emoji">🐱</text>
    </view>
    <view class="title-area">
      <text class="main-title">南雍猫札</text>
      <text class="sub-title">Nanjing University · Cat Chronicles</text>
    </view>
    <view class="motto">
      <text class="motto-text">「每一只猫猫，都值得被记住」</text>
      <text class="motto-location">—— 南京大学鼓楼校区</text>
    </view>
  </view>

  <!-- 功能入口卡片 -->
  <view class="feature-cards">
    
    <view class="feature-card" bindtap="navigateToMap">
      <view class="card-icon">🗺️</view>
      <view class="card-info">
        <text class="card-title">校园探索</text>
        <text class="card-desc">漫步水彩校园，邂逅猫咪朋友</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <view class="feature-card" bindtap="navigateToGallery">
      <view class="card-icon">📷</view>
      <view class="card-info">
        <text class="card-title">云吸猫画廊</text>
        <text class="card-desc">看看大家镜头下的猫咪日常</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <view class="feature-card disabled-card">
      <view class="card-icon">💬</view>
      <view class="card-info">
        <text class="card-title">猫友社区</text>
        <text class="card-desc">即将开放，敬请期待~</text>
      </view>
      <text class="card-tag">建设中</text>
    </view>

  </view>

  <!-- 统计区 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-number">{{totalCats}}</text>
      <text class="stat-label">只猫咪入驻</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{discoveredCount}}</text>
      <text class="stat-label">只已被发现</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{catSpots}}</text>
      <text class="stat-label">个常出没点</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-section">
    <text class="footer-text">🐾 用代码记录南大猫猫的温暖故事</text>
    <text class="footer-version">v0.1.0 Demo</text>
  </view>

</view>
