/* pages/cat/detail.wxss */
.detail-page {
  padding-bottom: 60rpx;
  background: var(--color-bg);
}

/* === 头部 === */
.detail-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #FFF8F0, #FBEBD9);
}

.header-photo-wrap {
  flex-shrink: 0;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid var(--color-border);
  box-shadow: var(--shadow-float);
}

.header-photo {
  width: 100%;
  height: 100%;
}

.header-info {
  flex: 1;
}

.header-name {
  font-family: var(--font-title);
  font-size: 44rpx;
  font-weight: bold;
  color: var(--color-text);
}

.header-nickname {
  display: block;
  font-size: 28rpx;
  color: var(--color-primary);
  margin-top: 4rpx;
}

.header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background: rgba(212, 119, 107, 0.1);
  border: 1rpx solid rgba(212, 119, 107, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* === 通用区块 === */
.section {
  margin: 24rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--color-border);
}

/* === 信息网格 === */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.info-cell {
  text-align: center;
  padding: 12rpx 8rpx;
}

.cell-icon { font-size: 36rpx; display: block; margin-bottom: 4rpx; }
.cell-label { font-size: 22rpx; color: var(--color-text-light); display: block; }
.cell-value { font-size: 24rpx; font-weight: 600; color: var(--color-text); display: block; margin-top: 2rpx; }

.status-ok { color: var(--color-green) !important; }
.status-warn { color: #E8A87C !important; }

/* === 描述 === */
.desc-text, .loc-text {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
}

/* === 亲属关系 === */
.family-tree {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.family-node {
  background: #FDF1E6;
  border-radius: var(--radius-sm);
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.family-relation {
  font-size: 22rpx;
  color: var(--color-text-light);
}

.family-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.family-hint {
  display: block;
  font-size: 22rpx;
  color: #CCC;
  margin-top: 12rpx;
}

/* === 照片区 === */
.photo-grid {
  display: flex;
}

.photo-empty {
  width: 100%;
  padding: 50rpx 0;
  text-align: center;
  background: #FAFAF8;
  border-radius: var(--radius-sm);
  border: 2rpx dashed var(--color-border);
}

.empty-icon { font-size: 60rpx; display: block; }
.empty-text { font-size: 26rpx; color: var(--color-text-light); display: block; margin-top: 12rpx; }
.empty-hint { font-size: 22rpx; color: #CCC; display: block; margin-top: 6rpx; }

/* === 返回按钮 === */
.back-btn-wrap { padding: 30rpx 32rpx; }

.back-btn {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  color: #FFF;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}
