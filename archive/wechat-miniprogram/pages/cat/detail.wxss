/* pages/cat/detail.wxss — Undertale 对话框风格猫咪档案 */
.detail-page {
  padding-bottom: 60rpx;
  background: #000000;
}

/* === 头部 — 黑色背景 + 白色边框对话框 === */
.detail-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
  background: #000000;
  border-bottom: 3rpx solid #FFFFFF;
}

.header-photo-wrap {
  flex-shrink: 0;
  width: 180rpx;
  height: 180rpx;
  overflow: hidden;
  border: 3rpx solid #FFFFFF;
  image-rendering: pixelated;
}

.header-photo {
  width: 100%;
  height: 100%;
}

.header-info {
  flex: 1;
}

.header-name {
  font-family: var(--font-title);
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.header-nickname {
  display: block;
  font-size: 28rpx;
  color: #FF0000;
  margin-top: 4rpx;
  font-family: var(--font-pixel);
}

.header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  color: #FFFFFF;
  background: #000000;
  border: 2rpx solid #FF0000;
  padding: 4rpx 16rpx;
  font-family: var(--font-pixel);
}

/* === 通用区块 — Undertale 对话框 === */
.section {
  margin: 24rpx 32rpx;
  background: #000000;
  border: 3rpx solid #FFFFFF;
  padding: 28rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FF0000;
  display: block;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #FFFFFF;
  font-family: var(--font-pixel);
}

/* === 信息网格 === */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.info-cell {
  text-align: center;
  padding: 12rpx 8rpx;
  border: 2rpx solid #333333;
}

.cell-icon { font-size: 36rpx; display: block; margin-bottom: 4rpx; }
.cell-label { font-size: 20rpx; color: #AAAAAA; display: block; font-family: var(--font-pixel); }
.cell-value { font-size: 22rpx; font-weight: 600; color: #FFFFFF; display: block; margin-top: 2rpx; font-family: var(--font-pixel); }

.status-ok { color: #00E500 !important; }
.status-warn { color: #FFD700 !important; }

/* === 描述 === */
.desc-text, .loc-text {
  font-size: 28rpx;
  color: #FFFFFF;
  line-height: 1.8;
  font-family: var(--font-pixel);
}

/* === 亲属关系 === */
.family-tree {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.family-node {
  background: #000000;
  border: 2rpx solid #FFFFFF;
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.family-relation {
  font-size: 20rpx;
  color: #AAAAAA;
  font-family: var(--font-pixel);
}

.family-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #FF0000;
  font-family: var(--font-pixel);
}

.family-hint {
  display: block;
  font-size: 20rpx;
  color: #666666;
  margin-top: 12rpx;
  font-family: var(--font-pixel);
}

/* === 照片区 === */
.photo-grid {
  display: flex;
}

.photo-empty {
  width: 100%;
  padding: 50rpx 0;
  text-align: center;
  background: #000000;
  border: 2rpx dashed #666666;
}

.empty-icon { font-size: 60rpx; display: block; }
.empty-text { font-size: 24rpx; color: #AAAAAA; display: block; margin-top: 12rpx; font-family: var(--font-pixel); }
.empty-hint { font-size: 20rpx; color: #666666; display: block; margin-top: 6rpx; font-family: var(--font-pixel); }

/* === 返回按钮 === */
.back-btn-wrap { padding: 30rpx 32rpx; }

.back-btn {
  width: 100%;
  height: 88rpx;
  background: #FF0000;
  color: #FFFFFF;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FFFFFF;
  font-family: var(--font-pixel);
}
