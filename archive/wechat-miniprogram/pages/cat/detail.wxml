<!-- pages/cat/detail.wxml - 猫咪完整档案页 -->
<view class="page-container detail-page">
  
  <!-- 头部：猫咪照片 -->
  <view class="detail-header">
    <view class="header-photo-wrap">
      <image 
        class="header-photo" 
        src="{{cat.photo || '/assets/default-cat.png'}}" 
        mode="aspectFill"
      />
    </view>
    <view class="header-info">
      <text class="header-name">{{cat.name}}</text>
      <text class="header-nickname" wx:if="{{cat.nickname}}">「{{cat.nickname}}」</text>
      <view class="header-tags">
        <text class="tag" wx:for="{{cat.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section info-section">
    <text class="section-title">📋 基本信息</text>
    <view class="info-grid">
      <view class="info-cell">
        <text class="cell-icon">🐱</text>
        <text class="cell-label">品种</text>
        <text class="cell-value">中华田园猫</text>
      </view>
      <view class="info-cell">
        <text class="cell-icon">{{cat.gender === 'male' ? '♂️' : '♀️'}}</text>
        <text class="cell-label">性别</text>
        <text class="cell-value">{{cat.gender === 'male' ? '男孩' : '女孩'}}</text>
      </view>
      <view class="info-cell">
        <text class="cell-icon">🎨</text>
        <text class="cell-label">花色</text>
        <text class="cell-value">{{cat.color}}</text>
      </view>
      <view class="info-cell">
        <text class="cell-icon">🏥</text>
        <text class="cell-label">绝育状态</text>
        <text class="cell-value {{cat.neutered ? 'status-ok' : 'status-warn'}}">
          {{cat.neutered ? '已绝育 ✅' : '未绝育 ⚠️'}}
        </text>
      </view>
      <view class="info-cell">
        <text class="cell-icon">🏠</text>
        <text class="cell-label">收养状态</text>
        <text class="cell-value {{cat.adopted ? 'status-ok' : ''}}">
          {{cat.adopted ? '已收养 🏠' : '校园自由猫 🏫'}}
        </text>
      </view>
      <view class="info-cell">
        <text class="cell-icon">📅</text>
        <text class="cell-label">首次发现</text>
        <text class="cell-value">{{cat.firstSeen || '未知'}}</text>
      </view>
    </view>
  </view>

  <!-- 性格介绍 -->
  <view class="section desc-section" wx:if="{{cat.description}}">
    <text class="section-title">📝 猫咪性格</text>
    <text class="desc-text">{{cat.description}}</text>
  </view>

  <!-- 常出没地点 -->
  <view class="section location-section" wx:if="{{cat.hangout}}">
    <text class="section-title">📍 常出没地点</text>
    <text class="loc-text">{{cat.hangout}}</text>
  </view>

  <!-- 亲属关系 -->
  <view class="section family-section" wx:if="{{cat.relations && cat.relations.length > 0}}">
    <text class="section-title">👨‍👩‍👧 亲属关系</text>
    <view class="family-tree">
      <view class="family-node" wx:for="{{cat.relations}}" wx:key="catId">
        <text class="family-relation">{{item.relation}}</text>
        <text class="family-name">{{item.name}}</text>
      </view>
    </view>
    <text class="family-hint">💡 以上关系基于同学们长期观察推测</text>
  </view>

  <!-- 用户近照上传区（预留） -->
  <view class="section upload-section">
    <text class="section-title">📸 猫咪近照</text>
    <view class="photo-grid">
      <view class="photo-empty">
        <text class="empty-icon">📷</text>
        <text class="empty-text">暂无用户上传的近照</text>
        <text class="empty-hint">功能即将开放~</text>
      </view>
    </view>
  </view>

  <!-- 回到地图 -->
  <view class="back-btn-wrap">
    <button class="back-btn" bindtap="goToMap">🗺️ 去地图找找{{cat.name}}</button>
  </view>

</view>
