/* pages/gallery/index.wxss — Undertale 图鉴风格 */
.gallery-page {
  background: #000000;
  min-height: 100vh;
}

/* === 头部 === */
.gallery-header {
  padding: 40rpx 0 20rpx;
  text-align: center;
}

.gallery-title {
  font-family: var(--font-title);
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
  text-shadow: 2rpx 2rpx 0rpx #FF0000;
}

.gallery-subtitle {
  font-size: 22rpx;
  color: #AAAAAA;
  display: block;
  margin-top: 8rpx;
  font-family: var(--font-pixel);
}

/* === 筛选栏 === */
.cat-filter {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}

.filter-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  font-size: 24rpx;
  background: #000000;
  color: #FFFFFF;
  border: 2rpx solid #FFFFFF;
  font-family: var(--font-pixel);
}

.filter-item.active {
  background: #FF0000;
  color: #FFFFFF;
  border-color: #FF0000;
}

/* === 照片网格 === */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 0 4rpx 60rpx;
}

.photo-card {
  width: calc(33.33% - 8rpx);
  aspect-ratio: 1;
  overflow: hidden;
  position: relative;
  border: 2rpx solid #FFFFFF;
  image-rendering: pixelated;
}

.photo-card.tall {
  aspect-ratio: 3/4;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  background: #000000;
  border-top: 2rpx solid #FFFFFF;
  padding: 8rpx 12rpx;
}

.photo-cat-name {
  font-size: 22rpx;
  color: #FF0000;
  font-weight: 600;
  display: block;
  font-family: var(--font-pixel);
}

.photo-date {
  font-size: 18rpx;
  color: #AAAAAA;
  display: block;
  font-family: var(--font-pixel);
}

/* === 空状态 === */
.photo-empty-state {
  width: 100%;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon { font-size: 100rpx; display: block; margin-bottom: 20rpx; }
.empty-title { font-size: 30rpx; color: #FFFFFF; display: block; margin-bottom: 10rpx; font-family: var(--font-pixel); }
.empty-desc { font-size: 26rpx; color: #AAAAAA; display: block; margin-bottom: 16rpx; font-family: var(--font-pixel); }
.empty-hint { font-size: 22rpx; color: #666666; display: block; font-family: var(--font-pixel); }

/* === 预览弹窗 === */
.preview-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.95);
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
}

.preview-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.preview-img {
  width: 90vw;
  height: 70vh;
}

.preview-info {
  padding: 30rpx;
  text-align: center;
}

.preview-name {
  font-size: 32rpx;
  color: #FFFFFF;
  display: block;
  font-family: var(--font-pixel);
}

.preview-date {
  font-size: 24rpx;
  color: #AAAAAA;
  display: block;
  margin-top: 6rpx;
  font-family: var(--font-pixel);
}
