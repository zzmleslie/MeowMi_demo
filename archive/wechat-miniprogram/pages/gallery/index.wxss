/* pages/gallery/index.wxss */
.gallery-page {
  background: var(--color-bg);
  min-height: 100vh;
}

/* === 头部 === */
.gallery-header {
  padding: 40rpx 0 20rpx;
  text-align: center;
}

.gallery-title {
  font-family: var(--font-title);
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text);
  display: block;
}

.gallery-subtitle {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: block;
  margin-top: 8rpx;
}

/* === 筛选栏 === */
.cat-filter {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 0;
  margin-bottom: 20rpx;
}

.filter-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  background: var(--color-bg-card);
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
}

.filter-item.active {
  background: var(--color-primary);
  color: #FFF;
  border-color: var(--color-primary);
}

/* === 照片网格 === */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 4rpx 60rpx;
}

.photo-card {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: var(--radius-sm);
  overflow: hidden;
  position: relative;
}

.photo-card.tall {
  aspect-ratio: 3/4;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  padding: 12rpx 16rpx;
}

.photo-cat-name {
  font-size: 24rpx;
  color: #FFF;
  font-weight: 600;
  display: block;
}

.photo-date {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  display: block;
}

/* === 空状态 === */
.photo-empty-state {
  width: 100%;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon { font-size: 100rpx; display: block; margin-bottom: 20rpx; }
.empty-title { font-size: 30rpx; color: var(--color-text); display: block; margin-bottom: 10rpx; }
.empty-desc { font-size: 26rpx; color: var(--color-text-light); display: block; margin-bottom: 16rpx; }
.empty-hint { font-size: 22rpx; color: #CCC; display: block; }

/* === 预览弹窗 === */
.preview-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.9);
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.preview-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.preview-img {
  width: 90vw;
  height: 70vh;
}

.preview-info {
  padding: 30rpx;
  text-align: center;
}

.preview-name {
  font-size: 32rpx;
  color: #FFF;
  display: block;
}

.preview-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-top: 6rpx;
}
